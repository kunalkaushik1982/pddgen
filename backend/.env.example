PDD_GENERATOR_APP_NAME=PDD Generator API
PDD_GENERATOR_APP_ENV=development
PDD_GENERATOR_APP_DEBUG=true
PDD_GENERATOR_API_PREFIX=/api
PDD_GENERATOR_DEMO_MODE=false
