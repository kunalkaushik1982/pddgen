PDD_GENERATOR_APP_NAME=PDD Generator API
PDD_GENERATOR_APP_ENV=development
PDD_GENERATOR_APP_DEBUG=true
PDD_GENERATOR_API_PREFIX=/api
PDD_GENERATOR_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pdd_generator
PDD_GENERATOR_REDIS_URL=redis://localhost:6379/0
# Optional: dedicated Redis for distributed locks (defaults to REDIS_URL).
# PDD_GENERATOR_LOCK_REDIS_URL=redis://localhost:6379/1
# Producer: celery | sqs | azure_service_bus | gcp_pubsub (JSON JobEnvelope; non-celery need consumers).
# Optional override: dotted path to (Settings) -> JobEnqueuePort — skips JOB_ENQUEUE_BACKEND when set (trusted paths only).
# PDD_GENERATOR_JOB_ENQUEUE_FACTORY=
# PDD_GENERATOR_JOB_ENQUEUE_BACKEND=celery
# Producer retry behavior (all backends): retries after first failure; backoff grows exponentially.
# PDD_GENERATOR_JOB_ENQUEUE_MAX_RETRIES=0
# PDD_GENERATOR_JOB_ENQUEUE_RETRY_BACKOFF_SECONDS=0.5
# PDD_GENERATOR_SQS_JOB_QUEUE_URL=
# Optional logical queue -> physical target mapping JSON.
# PDD_GENERATOR_SQS_JOB_QUEUE_URLS={"draft-generation":"https://sqs.us-east-1.amazonaws.com/123/a","screenshot-generation":"https://sqs.us-east-1.amazonaws.com/123/b"}
# PDD_GENERATOR_SQS_IS_FIFO_QUEUE=false
# PDD_GENERATOR_SQS_REGION=
# Azure Service Bus queue (connection string from portal; queue name only, not URL).
# PDD_GENERATOR_AZURE_SERVICE_BUS_CONNECTION_STRING=
# PDD_GENERATOR_AZURE_SERVICE_BUS_QUEUE_NAME=
# PDD_GENERATOR_AZURE_SERVICE_BUS_QUEUE_NAMES={"draft-generation":"draft-queue","screenshot-generation":"screenshot-queue"}
# GCP Pub/Sub topic (use Application Default Credentials or GOOGLE_APPLICATION_CREDENTIALS).
# PDD_GENERATOR_GCP_PUBSUB_PROJECT_ID=
# PDD_GENERATOR_GCP_PUBSUB_TOPIC_ID=
# PDD_GENERATOR_GCP_PUBSUB_TOPIC_IDS={"draft-generation":"draft-topic","screenshot-generation":"screenshot-topic"}
# Duplicate draft/screenshot job TTLs (Redis NX locks, seconds).
# PDD_GENERATOR_DRAFT_GENERATION_LOCK_SECONDS=3600
# PDD_GENERATOR_SCREENSHOT_GENERATION_LOCK_SECONDS=3600
# GPT-4o (OpenAI API): $2.50 / 1M input, $10 / 1M output → per 1k tokens in USD below.
PDD_GENERATOR_AI_ENABLED=false
PDD_GENERATOR_AI_PROVIDER=openai_compatible
PDD_GENERATOR_AI_API_KEY=
PDD_GENERATOR_AI_MODEL=gpt-4o
PDD_GENERATOR_AI_BASE_URL=https://api.openai.com/v1
PDD_GENERATOR_AI_TIMEOUT_SECONDS=180
# One batched LLM call after draft generation to polish export placeholders (stored on session; export stays AI-free).
PDD_GENERATOR_AI_DOCUMENT_EXPORT_ENRICHMENT_ENABLED=true
# BRD lean generation toggles (token/call optimization controls).
PDD_GENERATOR_AI_BRD_LEAN_MODE_ENABLED=false
PDD_GENERATOR_AI_BRD_TRANSCRIPT_TO_STEPS_MAX_STEPS=40
PDD_GENERATOR_AI_BRD_RUN_CAPABILITY_CLASSIFICATION_ONLY_FOR_MULTI_TRANSCRIPT=true
# Default include-diagram behavior when user does not pass an explicit toggle.
PDD_GENERATOR_AI_DRAFT_GENERATION_INCLUDE_DIAGRAM_DEFAULT=true
PDD_GENERATOR_AI_PROMPT_USD_PER_1K_TOKENS=0.0025
PDD_GENERATOR_AI_COMPLETION_USD_PER_1K_TOKENS=0.01
# Admin metrics: USD → INR, then charge column = actual INR × multiplier (1.5 = +50%).
PDD_GENERATOR_USD_TO_INR_RATE=83
PDD_GENERATOR_ADMIN_AI_COST_MARGIN_MULTIPLIER=1.5
# Optional: processing/storage estimate rates shown in per-session admin metrics.
PDD_GENERATOR_ADMIN_PROCESSING_INR_PER_MINUTE_DRAFT=0.5
PDD_GENERATOR_ADMIN_PROCESSING_INR_PER_MINUTE_SCREENSHOT=0.35
PDD_GENERATOR_ADMIN_STORAGE_INR_PER_GB_MONTH=2.0
PDD_GENERATOR_ADMIN_STORAGE_RETENTION_DAYS=30
# Per-user job units (new session + each generate/screenshot run). Admins are unlimited.
PDD_GENERATOR_USER_QUOTA_LIFETIME_JOBS=4
PDD_GENERATOR_USER_QUOTA_DAILY_JOBS=4
PDD_GENERATOR_STORAGE_BACKEND=local
PDD_GENERATOR_LOCAL_STORAGE_ROOT=C:\Users\work\Documents\PddGenerator\storage\local
PDD_GENERATOR_MAX_UPLOAD_SIZE_MB=1024
PDD_GENERATOR_DOCX_OUTPUT_FOLDER=exports

PDD_GENERATOR_SCREENSHOT_CANDIDATE_COUNT=5
PDD_GENERATOR_SCREENSHOT_SELECTED_COUNT=3
PDD_GENERATOR_SCREENSHOT_SHORT_WINDOW_SECONDS=3
PDD_GENERATOR_SCREENSHOT_MEDIUM_WINDOW_SECONDS=8
PDD_GENERATOR_SCREENSHOT_LONG_WINDOW_SECONDS=20
PDD_GENERATOR_SCREENSHOT_ANCHOR_CANDIDATE_CAP=5
PDD_GENERATOR_SCREENSHOT_SHORT_WINDOW_CANDIDATE_CAP=3
PDD_GENERATOR_SCREENSHOT_MEDIUM_WINDOW_CANDIDATE_CAP=5
PDD_GENERATOR_SCREENSHOT_LONG_WINDOW_CANDIDATE_CAP=7
PDD_GENERATOR_SCREENSHOT_EXTENDED_WINDOW_CANDIDATE_CAP=9

# Celery task time limits (seconds). Screenshot defaults: 5m soft / 5.5m hard. Draft: 1h+.
PDD_GENERATOR_SCREENSHOT_CELERY_SOFT_TIME_LIMIT_SECONDS=300
PDD_GENERATOR_SCREENSHOT_CELERY_TIME_LIMIT_SECONDS=330
PDD_GENERATOR_DRAFT_CELERY_SOFT_TIME_LIMIT_SECONDS=3600
PDD_GENERATOR_DRAFT_CELERY_TIME_LIMIT_SECONDS=3720
# After this age, "Extracting screenshots" is shown as stalled and processing sessions may reconcile to review.
PDD_GENERATOR_SCREENSHOT_EXTRACTION_STALE_AFTER_SECONDS=300
# If draft generation started this long ago with no completion timestamp, reconcile processing to failed (unlock retry).
PDD_GENERATOR_DRAFT_GENERATION_STALE_AFTER_SECONDS=600

# Optional Google auth support (frontend still keeps password fallback).
# PDD_GENERATOR_AUTH_GOOGLE_ENABLED=false
# PDD_GENERATOR_AUTH_GOOGLE_CLIENT_ID=
# PDD_GENERATOR_AUTH_GOOGLE_AUTO_CREATE_USER=true

# Password reset flow.
# PDD_GENERATOR_AUTH_PASSWORD_RESET_ENABLED=true
# PDD_GENERATOR_AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Development/testing only: include token in API response from /auth/password-reset/request.
# PDD_GENERATOR_AUTH_PASSWORD_RESET_RETURN_TOKEN_IN_RESPONSE=false

# Email verification + password reset links (no trailing slash).
# PDD_GENERATOR_AUTH_PUBLIC_APP_URL=http://localhost:5173
# PDD_GENERATOR_AUTH_API_PUBLIC_BASE_URL=http://localhost:8000

# SMTP for verification and password-reset mail. When empty, new accounts get email_verified immediately (local dev).
# Production: set host + credentials so users receive verification and reset links.
# PDD_GENERATOR_SMTP_HOST=
# PDD_GENERATOR_SMTP_PORT=587
# PDD_GENERATOR_SMTP_USER=
# PDD_GENERATOR_SMTP_PASSWORD=
# PDD_GENERATOR_SMTP_FROM_EMAIL=
# PDD_GENERATOR_SMTP_USE_TLS=true
# PDD_GENERATOR_AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=2880

# Payments (Stripe + Razorpay). Leave empty to disable that provider.
# PDD_GENERATOR_PAYMENT_STRIPE_SECRET_KEY=
# PDD_GENERATOR_PAYMENT_STRIPE_PUBLISHABLE_KEY=
# PDD_GENERATOR_PAYMENT_STRIPE_WEBHOOK_SECRET=
# PDD_GENERATOR_PAYMENT_RAZORPAY_KEY_ID=
# PDD_GENERATOR_PAYMENT_RAZORPAY_KEY_SECRET=
# PDD_GENERATOR_PAYMENT_RAZORPAY_WEBHOOK_SECRET=
# Optional JSON array of URL prefixes; when set, checkout success_url and cancel_url must start with one of them.
# PDD_GENERATOR_PAYMENT_CHECKOUT_REDIRECT_ALLOWLIST=["http://localhost:5173","https://app.example.com"]
#
# GST tax invoices (India): enable after setting seller details. Users may set GSTIN via PATCH /api/payments/billing-profile.
# PDD_GENERATOR_BILLING_GST_INVOICE_ENABLED=false
# PDD_GENERATOR_BILLING_SELLER_LEGAL_NAME=
# PDD_GENERATOR_BILLING_SELLER_GSTIN=
# PDD_GENERATOR_BILLING_SELLER_ADDRESS=
# PDD_GENERATOR_BILLING_SELLER_STATE_CODE=
# PDD_GENERATOR_BILLING_DEFAULT_HSN_SAC=998313
# PDD_GENERATOR_BILLING_DEFAULT_GST_RATE_BPS=1800
# PDD_GENERATOR_BILLING_SUPPLY_DEFAULT=intrastate
#
# Billing catalog: insert rows into billing_products (sku, kind, title, credits_*, amount_minor, currency,
# stripe_price_id for subscriptions, stripe_checkout_mode payment|subscription). Then POST /api/payments/checkout
# with { "provider": "stripe", "product_sku": "...", "success_url": "...", "cancel_url": "..." }.
