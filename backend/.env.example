PDD_GENERATOR_APP_NAME=PDD Generator API
PDD_GENERATOR_APP_ENV=development
PDD_GENERATOR_APP_DEBUG=true
PDD_GENERATOR_API_PREFIX=/api
PDD_GENERATOR_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pdd_generator
PDD_GENERATOR_REDIS_URL=redis://localhost:6379/0
# Optional: dedicated Redis for distributed locks (defaults to REDIS_URL).
# PDD_GENERATOR_LOCK_REDIS_URL=redis://localhost:6379/1
PDD_GENERATOR_AI_ENABLED=false
PDD_GENERATOR_AI_PROVIDER=openai_compatible
PDD_GENERATOR_AI_API_KEY=
PDD_GENERATOR_AI_MODEL=gpt-4.1-mini
PDD_GENERATOR_AI_BASE_URL=https://api.openai.com/v1
PDD_GENERATOR_AI_TIMEOUT_SECONDS=180
PDD_GENERATOR_STORAGE_BACKEND=local
PDD_GENERATOR_LOCAL_STORAGE_ROOT=C:\Users\work\Documents\PddGenerator\storage\local
PDD_GENERATOR_MAX_UPLOAD_SIZE_MB=1024
PDD_GENERATOR_DOCX_OUTPUT_FOLDER=exports

PDD_GENERATOR_SCREENSHOT_CANDIDATE_COUNT=5
PDD_GENERATOR_SCREENSHOT_SELECTED_COUNT=3
PDD_GENERATOR_SCREENSHOT_SHORT_WINDOW_SECONDS=3
PDD_GENERATOR_SCREENSHOT_MEDIUM_WINDOW_SECONDS=8
PDD_GENERATOR_SCREENSHOT_LONG_WINDOW_SECONDS=20
PDD_GENERATOR_SCREENSHOT_ANCHOR_CANDIDATE_CAP=5
PDD_GENERATOR_SCREENSHOT_SHORT_WINDOW_CANDIDATE_CAP=3
PDD_GENERATOR_SCREENSHOT_MEDIUM_WINDOW_CANDIDATE_CAP=5
PDD_GENERATOR_SCREENSHOT_LONG_WINDOW_CANDIDATE_CAP=7
PDD_GENERATOR_SCREENSHOT_EXTENDED_WINDOW_CANDIDATE_CAP=9

# Celery task time limits (seconds). Screenshot defaults: 5m soft / 5.5m hard. Draft: 1h+.
PDD_GENERATOR_SCREENSHOT_CELERY_SOFT_TIME_LIMIT_SECONDS=300
PDD_GENERATOR_SCREENSHOT_CELERY_TIME_LIMIT_SECONDS=330
PDD_GENERATOR_DRAFT_CELERY_SOFT_TIME_LIMIT_SECONDS=3600
PDD_GENERATOR_DRAFT_CELERY_TIME_LIMIT_SECONDS=3720
# After this age, "Extracting screenshots" is shown as stalled and processing sessions may reconcile to review.
PDD_GENERATOR_SCREENSHOT_EXTRACTION_STALE_AFTER_SECONDS=300
